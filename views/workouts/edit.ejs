<%- include('../partials/header') %>

<section class="form-page">
    <h1>Edit Workout</h1>

    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/workouts/<%= workout.id %>/edit" method="POST" class="form-card">

        <div class="form-group">
            <label for="exercise_name">Exercise Name *</label>
            <input type="text" id="exercise_name" name="exercise_name"
                   value="<%= workout.exercise_name %>" required>
        </div>

        <div class="form-group">
            <label for="category">Category *</label>
            <select id="category" name="category" required>
                <option value="">-- Select a category --</option>
                <% ['Strength', 'Cardio', 'Flexibility', 'Sport', 'Other'].forEach(cat => { %>
                    <option value="<%= cat %>" <%= workout.category === cat ? 'selected' : '' %>>
                        <%= cat %>
                    </option>
                <% }) %>
            </select>
        </div>

        <div class="form-group">
            <label for="duration_mins">Duration (minutes)</label>
            <input type="number" id="duration_mins" name="duration_mins" min="1"
                   value="<%= workout.duration_mins || '' %>">
        </div>

        <div class="form-group">
            <label for="workout_date">Date *</label>
            <!--
                MySQL returns workout_date as a JS Date object, not a plain string.
                .toISOString().slice(0, 10) converts it to YYYY-MM-DD which the date input needs.
            -->
            <input type="date" id="workout_date" name="workout_date"
                   value="<%= new Date(workout.workout_date).toISOString().slice(0, 10) %>" required>
        </div>

        <div class="form-group">
            <label for="notes">Notes</label>
            <textarea id="notes" name="notes" rows="3"><%= workout.notes || '' %></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Update Workout</button>
            <a href="/workouts" class="btn-secondary">Cancel</a>
        </div>
    </form>
</section>

<%- include('../partials/footer') %>
