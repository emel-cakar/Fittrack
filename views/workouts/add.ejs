<%- include('../partials/header') %>

<section class="form-page">
    <h1>Log a Workout</h1>

    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/workouts/add" method="POST" class="form-card">

        <div class="form-group">
            <label for="exercise_name">Exercise Name *</label>
            <!-- old.exercise_name repopulates the field if validation fails -->
            <input type="text" id="exercise_name" name="exercise_name"
                   placeholder="e.g. Running, Bench Press, Yoga"
                   value="<%= old.exercise_name || '' %>" required>
        </div>

        <div class="form-group">
            <label for="category">Category *</label>
            <select id="category" name="category" required>
                <option value="">-- Select a category --</option>
                <% ['Strength', 'Cardio', 'Flexibility', 'Sport', 'Other'].forEach(cat => { %>
                    <option value="<%= cat %>" <%= old.category === cat ? 'selected' : '' %>>
                        <%= cat %>
                    </option>
                <% }) %>
            </select>
        </div>

        <div class="form-group">
            <label for="duration_mins">Duration (minutes)</label>
            <input type="number" id="duration_mins" name="duration_mins" min="1"
                   placeholder="e.g. 30"
                   value="<%= old.duration_mins || '' %>">
        </div>

        <div class="form-group">
            <label for="workout_date">Date *</label>
            <input type="date" id="workout_date" name="workout_date"
                   value="<%= old.workout_date || '' %>" required>
        </div>

        <div class="form-group">
            <label for="notes">Notes</label>
            <textarea id="notes" name="notes" rows="3"
                      placeholder="How did it go? Any personal bests?"><%= old.notes || '' %></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Save Workout</button>
            <a href="/workouts" class="btn-secondary">Cancel</a>
        </div>
    </form>
</section>

<%- include('../partials/footer') %>
